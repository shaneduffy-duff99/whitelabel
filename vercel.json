    { "src": "/admin/broker-admin", "dest": "/public/admin/broker-admin.html" },
    { "src": "/admin/marketplace-admin", "dest": "/public/admin/marketplace-admin.html" },
    { "src": "/admin/clients", "dest": "/public/admin/clients.html" },
